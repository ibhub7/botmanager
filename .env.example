# ── Telegram ──────────────────────────────────────────
API_ID=12345678
API_HASH=your_api_hash_here
BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── MongoDB ───────────────────────────────────────────
MONGO_URL=mongodb+srv://user:pass@cluster.mongodb.net/

# ── Owner & Logging ───────────────────────────────────
OWNER_ID=123456789
LOG_CHANNEL=-100123456789

# ── Bot Appearance ────────────────────────────────────
START_PIC=https://telegra.ph/file/your-image.jpg
BOT_USERNAME=YourBotUsername

# ── Koyeb (optional) ──────────────────────────────────
KOYEB_APP_NAME=your-app-name
KOYEB_API_KEY=your_koyeb_api_key

# ── Web Server ────────────────────────────────────────
PORT=8080
