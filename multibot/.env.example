# ════════════════════════════════════════════════════════
#  MultiBot System v2 — Environment Variables
#  Copy this to .env and fill in your values
# ════════════════════════════════════════════════════════

# ── Telegram API (get from https://my.telegram.org) ──────
API_ID=12345678
API_HASH=your_api_hash_here

# ── Master Bot Token (from @BotFather) ───────────────────
MASTER_TOKEN=123456789:ABCdef...

# ── MongoDB ──────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
DB_NAME=multibot_system

# ── Admins (space-separated Telegram user IDs) ───────────
ADMINS=123456789 987654321

# ── Broadcast Performance ────────────────────────────────
BATCH_SIZE=80
CONCURRENCY=15
MIN_DELAY=0.05
MAX_DELAY=0.15
RETRY_DELAY=0.3

# ── Anti-ban ─────────────────────────────────────────────
BOT_RATE_LIMIT=25

# ── Sessions Directory ───────────────────────────────────
SESSIONS_DIR=sessions

# ── Web Dashboard ────────────────────────────────────────
WEB_HOST=0.0.0.0
WEB_PORT=8080
DASHBOARD_TOKEN=changeme_use_a_strong_secret

# ── Log Channel (set to 0 to disable) ────────────────────
# Use a channel/group ID (e.g. -1001234567890)
LOG_CHANNEL=0
