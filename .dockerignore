**/__pycache__/
*.pyc
*.pyo
*.pyd
*.pycache

# Dev/editor
.git/
.gitignore
.venv/
venv/
*.egg-info/

# Docs (not needed at runtime)
README.md
*.md

# OS
.DS_Store
Thumbs.db
